{
  "name": "vibe-checker",
  "displayName": "Vibe Checker",
  "description": "Inline ghost text for vibe violations",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onLanguage:python",
    "onCommand:vibe-checker.checkWorkspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibe-checker.checkWorkspace",
        "title": "Vibe Checker: Check Workspace"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.0.0"
  }
}
